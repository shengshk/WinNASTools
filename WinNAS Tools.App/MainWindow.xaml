<Window x:Class="WinNASTools.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinNAS Tools"
        Height="600" Width="520"
        MinHeight="600"
        MaxHeight="1500"
        ResizeMode="CanMinimize"
        ShowActivated="False"
        ShowInTaskbar="False"
        Visibility="Hidden"
        WindowStartupLocation="CenterScreen"
        FontFamily="Microsoft YaHei UI, Segoe UI"
        FontSize="12"
        Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
        PreviewMouseDown="Window_PreviewMouseDown">
  <Window.Resources>
    <!-- 按钮样式在 App.xaml；此处仅 Tab -->
    <Style x:Key="EqualTabControl" TargetType="TabControl">
      <Setter Property="Padding" Value="0"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TabControl">
            <Grid Background="Transparent">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="4"/>
                <RowDefinition Height="*"/>
              </Grid.RowDefinitions>
              <UniformGrid x:Name="HeaderPanel" Grid.Row="0" Rows="1" IsItemsHost="True"/>
              <Border Grid.Row="2"
                      Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                      BorderBrush="#C0C0C0"
                      BorderThickness="1">
                <ContentPresenter ContentSource="SelectedContent" Margin="0"/>
              </Border>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style TargetType="TabItem">
      <Setter Property="Padding" Value="8,4"/>
      <Setter Property="Margin" Value="0"/>
      <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TabItem">
            <Border x:Name="Bd" Background="{StaticResource FlatBtnBg}" BorderThickness="0"
                    Padding="{TemplateBinding Padding}" Cursor="Hand">
              <TextBlock x:Name="Title"
                         Text="{TemplateBinding Header}"
                         FontFamily="{TemplateBinding FontFamily}"
                         FontSize="{TemplateBinding FontSize}"
                         HorizontalAlignment="Center" VerticalAlignment="Center"
                         Foreground="{StaticResource FlatBtnFg}"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{StaticResource FlatBtnBgActive}"/>
                <Setter TargetName="Title" Property="Foreground" Value="{StaticResource FlatBtnFgActive}"/>
                <Setter TargetName="Title" Property="FontWeight" Value="SemiBold"/>
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{StaticResource FlatBtnBgHover}"/>
              </Trigger>
              <MultiTrigger>
                <MultiTrigger.Conditions>
                  <Condition Property="IsSelected" Value="True"/>
                  <Condition Property="IsMouseOver" Value="True"/>
                </MultiTrigger.Conditions>
                <Setter TargetName="Bd" Property="Background" Value="{StaticResource FlatBtnBgActive}"/>
              </MultiTrigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Grid Grid.Row="0" Margin="16,3,16,0">
      <Grid.RowDefinitions>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="140"/>
      </Grid.RowDefinitions>

    <TabControl Grid.Row="0" x:Name="MainTabs" Style="{StaticResource EqualTabControl}">
      <!-- 离开 / 归来 -->
      <TabItem x:Name="TabLeave" Header="离开/归来">
        <ScrollViewer x:Name="ScrollLeave" VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Disabled"
                      Padding="8,10,8,8" CanContentScroll="False">
          <StackPanel>
            <StackPanel x:Name="BlockWindow">
              <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <CheckBox x:Name="ChkWindow" IsChecked="True" VerticalAlignment="Center" HorizontalAlignment="Left"
                          Checked="FeatureCheck_Changed" Unchecked="FeatureCheck_Changed"/>
                <TextBlock Grid.Column="1" Text="自动隐藏窗口" VerticalAlignment="Center" Margin="8,0,8,0"
                           ToolTip="作用：离开时最小化所有普通窗口，桌面和任务栏除外。&#x0a;工作：空闲到时或一键离开时执行；检测到键鼠活动后恢复原窗口状态。"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                  <TextBox x:Name="TxtHideAfter" Width="72" Height="23"
                           ToolTip="空闲多久后隐藏窗口" LostFocus="Setting_LostFocus"/>
                  <TextBlock Text="秒" Margin="6,0,0,0" VerticalAlignment="Center" Foreground="#555555"/>
                </StackPanel>
              </Grid>
            </StackPanel>

            <StackPanel x:Name="BlockPower">
              <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <CheckBox x:Name="ChkPower" IsChecked="True" VerticalAlignment="Center" HorizontalAlignment="Left"
                          Checked="FeatureCheck_Changed" Unchecked="FeatureCheck_Changed"/>
                <TextBlock x:Name="LblPower" Grid.Column="1" Text="自动电源模式" VerticalAlignment="Center" Margin="8,0,8,0"
                           Cursor="Hand" MouseLeftButtonUp="MainRow_Click" Tag="power"
                           ToolTip="作用：离开时切换到节能电源计划。&#x0a;工作：空闲到时或一键离开时执行；归来后恢复所选性能/平衡计划，手动模式不自动切换。"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                  <TextBox x:Name="TxtSaverAfter" Width="72" Height="23"
                           ToolTip="空闲多久后切换节能" LostFocus="Setting_LostFocus"/>
                  <TextBlock Text="秒" Margin="6,0,0,0" VerticalAlignment="Center" Foreground="#555555"/>
                </StackPanel>
              </Grid>
              <Grid x:Name="RowPowerMode" Margin="24,0,0,6">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="电源偏好模式" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                  <ComboBox x:Name="CmbPowerMode" Width="72" Height="23"
                            SelectionChanged="Setting_Changed">
                    <ComboBoxItem Content="性能" Tag="Performance" IsSelected="True"/>
                    <ComboBoxItem Content="平衡" Tag="Balanced"/>
                    <ComboBoxItem Content="手动" Tag="Manual"/>
                  </ComboBox>
                  <TextBlock Text="秒" Margin="6,0,0,0" VerticalAlignment="Center" Visibility="Hidden"/>
                </StackPanel>
              </Grid>
            </StackPanel>

            <StackPanel x:Name="BlockMedia">
              <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <CheckBox x:Name="ChkMedia" IsChecked="True" VerticalAlignment="Center" HorizontalAlignment="Left"
                          Checked="FeatureCheck_Changed" Unchecked="FeatureCheck_Changed"/>
                <TextBlock x:Name="LblMedia" Grid.Column="1" Text="自动停止音乐" VerticalAlignment="Center" Margin="8,0,8,0"
                           Cursor="Hand" MouseLeftButtonUp="MainRow_Click" Tag="media"
                           ToolTip="作用：离开时仅在检测到音频播放后阶梯暂停（系统键→自定义快捷键→静音）。&#x0a;工作：空闲到时或一键离开时执行；归来时用离开生效的同一方式恢复。"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                  <TextBox x:Name="TxtMediaStop" Width="72" Height="23"
                           ToolTip="空闲多久后停止音乐" LostFocus="Setting_LostFocus"/>
                  <TextBlock Text="秒" Margin="6,0,0,0" VerticalAlignment="Center" Foreground="#555555"/>
                </StackPanel>
              </Grid>
              <Grid x:Name="RowMediaResume" Margin="24,0,0,6">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="自动恢复音乐" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                  <ComboBox x:Name="CmbMediaResume" Width="72" Height="23"
                            SelectionChanged="Setting_Changed">
                    <ComboBoxItem Content="开启" Tag="True" IsSelected="True"/>
                    <ComboBoxItem Content="不开启" Tag="False"/>
                  </ComboBox>
                  <TextBlock Text="秒" Margin="6,0,0,0" VerticalAlignment="Center" Visibility="Hidden"/>
                </StackPanel>
              </Grid>
              <StackPanel x:Name="RowMediaHotkeys" Margin="24,0,0,6"
                          Focusable="True" LostFocus="RowMediaHotkeys_LostFocus">
                <TextBlock x:Name="LblMediaHotkeys"
                           Text="播放/暂停快捷键 （兜底控制，可留空）"
                           Cursor="Hand"
                           Foreground="#555555"
                           Margin="0,0,0,4"
                           MouseLeftButtonUp="LblMediaHotkeys_Click"
                           ToolTip="点击展开/折叠。播放器自带的播放/暂停全局快捷键，最多 3 组；可留空。系统媒体键无效时按顺序尝试，仍无效再系统静音。"/>
                <StackPanel x:Name="PanelMediaHotkeySlots" Visibility="Collapsed">
                  <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                      <TextBlock Text="1" Width="16" Foreground="#888888" VerticalAlignment="Center"/>
                      <TextBlock x:Name="TxtMediaHotkey1" Text="Ctrl+Alt+Up" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                      <Button Content="设置" Width="72" Height="23" Click="BtnMediaHotkey1_Click"
                              ToolTip="录制第 1 组播放/暂停快捷键"/>
                      <TextBlock Text="秒" Margin="6,0,0,0" VerticalAlignment="Center" Visibility="Hidden"/>
                    </StackPanel>
                  </Grid>
                  <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                      <TextBlock Text="2" Width="16" Foreground="#888888" VerticalAlignment="Center"/>
                      <TextBlock x:Name="TxtMediaHotkey2" Text="Ctrl+Alt+P" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                      <Button Content="设置" Width="72" Height="23" Click="BtnMediaHotkey2_Click"
                              ToolTip="录制第 2 组播放/暂停快捷键"/>
                      <TextBlock Text="秒" Margin="6,0,0,0" VerticalAlignment="Center" Visibility="Hidden"/>
                    </StackPanel>
                  </Grid>
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                      <TextBlock Text="3" Width="16" Foreground="#888888" VerticalAlignment="Center"/>
                      <TextBlock x:Name="TxtMediaHotkey3" Text="Ctrl+Shift+P" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                      <Button Content="设置" Width="72" Height="23" Click="BtnMediaHotkey3_Click"
                              ToolTip="录制第 3 组播放/暂停快捷键"/>
                      <TextBlock Text="秒" Margin="6,0,0,0" VerticalAlignment="Center" Visibility="Hidden"/>
                    </StackPanel>
                  </Grid>
                </StackPanel>
              </StackPanel>
            </StackPanel>

            <StackPanel x:Name="BlockBrowser">
              <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <CheckBox x:Name="ChkBrowser" VerticalAlignment="Center" HorizontalAlignment="Left"
                          Checked="FeatureCheck_Changed" Unchecked="FeatureCheck_Changed"/>
                <TextBlock x:Name="LblBrowser" Grid.Column="1" Text="自动关闭浏览器" VerticalAlignment="Center" Margin="8,0,8,0"
                           Cursor="Hand" MouseLeftButtonUp="MainRow_Click" Tag="browser"
                           ToolTip="作用：离开时关闭配置的浏览器进程。&#x0a;工作：先请求正常退出并等待，超时后强制结束；归来时不会重新启动。"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                  <TextBox x:Name="TxtBrowserClose" Width="72" Height="23"
                           ToolTip="空闲多久后结束浏览器进程" LostFocus="Setting_LostFocus"/>
                  <TextBlock Text="秒" Margin="6,0,0,0" VerticalAlignment="Center" Foreground="#555555"/>
                </StackPanel>
              </Grid>
              <Grid x:Name="RowBrowserProcs" Margin="24,0,0,6">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="80"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="进程列表" VerticalAlignment="Center" ToolTip="逗号分隔，如 chrome,msedge,firefox"/>
                <TextBox x:Name="TxtBrowserProcs" Grid.Column="1" Height="23" Margin="0,0,18,0"
                         Style="{StaticResource OptionalTextBox}"
                         Tag="留空：使用 chrome、msedge、firefox"
                         VerticalAlignment="Center"
                         LostFocus="Setting_LostFocus"/>
              </Grid>
            </StackPanel>

            <StackPanel x:Name="BlockAppSwitch">
              <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <CheckBox x:Name="ChkAppSwitchModule" VerticalAlignment="Center" HorizontalAlignment="Left"
                          Checked="AppSwitchModule_Changed" Unchecked="AppSwitchModule_Changed"/>
                <TextBlock x:Name="LblAppSwitch" Grid.Column="1" Text="自动停止应用" VerticalAlignment="Center" Margin="8,0,8,0"
                           Cursor="Hand" MouseLeftButtonUp="MainRow_Click" Tag="appswitch"
                           ToolTip="作用：按子任务停止指定应用。&#x0a;工作：每个任务独立倒计时；仅本程序实际停止且启用归来重启时，归来后启动。"/>
                <Button x:Name="BtnAppSwitchSave" Grid.Column="2" Content="保存" Padding="14,0"
                        Click="BtnAppSwitchSave_Click" IsEnabled="False" Visibility="Collapsed"/>
              </Grid>

              <StackPanel x:Name="PanelAppSwitchBody" Margin="0,0,0,6">
                <ListBox x:Name="LstAppSwitchTasks"
                         Margin="0,0,0,8"
                         BorderThickness="1"
                         Padding="0"
                         Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.CanContentScroll="False"
                         PreviewMouseRightButtonDown="LstAppSwitchTasks_PreviewMouseRightButtonDown"
                         SelectionChanged="LstAppSwitchTasks_SelectionChanged">
                  <ListBox.ContextMenu>
                    <ContextMenu>
                      <MenuItem Header="重命名" Click="MenuRenameAppSwitch_Click"/>
                    </ContextMenu>
                  </ListBox.ContextMenu>
                  <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                      <Setter Property="Padding" Value="6,2"/>
                      <Setter Property="FontSize" Value="12"/>
                      <Setter Property="FontWeight" Value="Normal"/>
                      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                      <Setter Property="Background" Value="Transparent"/>
                      <Setter Property="BorderThickness" Value="0"/>
                      <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                      <Setter Property="Template">
                        <Setter.Value>
                          <ControlTemplate TargetType="ListBoxItem">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderThickness="0"
                                    Padding="{TemplateBinding Padding}">
                              <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"
                                                TextElement.FontSize="{TemplateBinding FontSize}"
                                                TextElement.FontWeight="{TemplateBinding FontWeight}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                              <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#D0E4F7"/>
                              </Trigger>
                              <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E8F0F8"/>
                              </Trigger>
                              <MultiTrigger>
                                <MultiTrigger.Conditions>
                                  <Condition Property="IsSelected" Value="True"/>
                                  <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#D0E4F7"/>
                              </MultiTrigger>
                            </ControlTemplate.Triggers>
                          </ControlTemplate>
                        </Setter.Value>
                      </Setter>
                    </Style>
                  </ListBox.ItemContainerStyle>
                </ListBox>

                <Grid Margin="0,0,0,10" x:Name="PanelAppSwitchActions">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <Button Grid.Column="0" Content="新建" Click="BtnAppSwitchAdd_Click"/>
                  <Button Grid.Column="1" Content="删除" Click="BtnAppSwitchDelete_Click"/>
                  <Button x:Name="BtnAppSwitchPause" Grid.Column="2" Content="暂停" Click="BtnAppSwitchPause_Click"/>
                </Grid>

                <Grid x:Name="PanelAppSwitchEdit" IsEnabled="False">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="56"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                  </Grid.RowDefinitions>

                  <TextBlock Grid.Row="0" Text="名称" VerticalAlignment="Center" Margin="0,0,0,6"/>
                  <TextBox x:Name="TxtAppName" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Height="23" Margin="0,0,0,6"
                           TextChanged="AppSwitchDraft_Changed"/>

                  <TextBlock Grid.Row="1" Text="方式" VerticalAlignment="Center" Margin="0,0,0,6"/>
                  <Grid Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="BtnAppModeSelect" Grid.Column="0" Content="选择应用" Margin="0,0,3,0"
                            Click="BtnAppModeSelect_Click"
                            ToolTip="从运行中的应用选择；路径自动带出且不可改"/>
                    <Button x:Name="BtnAppModePath" Grid.Column="1" Content="指定路径" Margin="3,0,0,0"
                            Click="BtnAppModePath_Click"
                            ToolTip="以 exe 路径为账本；自动反查应用并显示运行状态"/>
                  </Grid>

                  <TextBlock Grid.Row="2" Text="应用" VerticalAlignment="Center" Margin="0,0,0,6"/>
                  <Grid Grid.Row="2" Grid.Column="1" Margin="0,0,0,6">
                    <ComboBox x:Name="CmbAppProcess" Height="23"
                              IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True"
                              MaxDropDownHeight="220"
                              ToolTip="点开下拉选择运行中的应用；输入文字可按应用名、进程名或窗口标题筛选"
                              DropDownOpened="CmbAppProcess_DropDownOpened"
                              SelectionChanged="CmbAppProcess_SelectionChanged">
                      <ComboBox.ItemTemplate>
                        <DataTemplate>
                          <TextBlock Text="{Binding Display}"
                                     MaxWidth="300"
                                     TextTrimming="CharacterEllipsis"
                                     ToolTip="{Binding FullDisplay}"/>
                        </DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBox x:Name="TxtAppBound" Height="23" IsReadOnly="True"
                             Visibility="Collapsed"
                             ToolTip="由路径反查得到；运行中/未运行会随扫描更新"/>
                  </Grid>
                  <Button x:Name="BtnAppListMode" Grid.Row="2" Grid.Column="2" Content="普通" Width="56"
                          Margin="6,0,0,6" Click="BtnAppListMode_Click"
                          ToolTip="普通：仅有可见窗口的应用&#x0a;复杂：当前会话真实应用（含托盘/后台，排除系统进程）"/>

                  <TextBlock Grid.Row="3" Text="路径" VerticalAlignment="Center" Margin="0,0,0,6"/>
                  <TextBox x:Name="TxtAppLaunch" Grid.Row="3" Grid.Column="1" Height="23" Margin="0,0,0,6"
                           Style="{StaticResource OptionalTextBox}"
                           Tag="选择模式下由应用自动带出"
                           ToolTip="exe 完整路径；选择模式只读，指定路径模式可编辑"
                           TextChanged="TxtAppLaunch_TextChanged"/>
                  <Button x:Name="BtnBrowseAppLaunch" Grid.Row="3" Grid.Column="2" Content="浏览" Width="48" Margin="6,0,0,6"
                          Click="BtnBrowseAppLaunch_Click"/>

                  <TextBlock Grid.Row="4" Text="归来" VerticalAlignment="Center" Margin="0,0,0,6"/>
                  <Grid Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="CmbAppRestart" Width="88" Height="23" HorizontalAlignment="Left"
                              ToolTip="归来时若上次因离开被停止，是否重新启动"
                              SelectionChanged="AppSwitchDraft_Changed">
                      <ComboBoxItem Content="重启" Tag="True" IsSelected="True"/>
                      <ComboBoxItem Content="不重启" Tag="False"/>
                    </ComboBox>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                      <TextBlock Text="空闲" VerticalAlignment="Center" Margin="0,0,6,0"/>
                      <TextBox x:Name="TxtAppStopAfter" Width="72" Height="23"
                               ToolTip="空闲多久后停止；0 表示仅一键离开时停止" TextChanged="AppSwitchDraft_Changed"/>
                      <TextBlock Text="秒" Margin="6,0,0,0" VerticalAlignment="Center" Foreground="#555555"/>
                    </StackPanel>
                  </Grid>
                </Grid>
              </StackPanel>
            </StackPanel>

            <StackPanel x:Name="BlockLock">
              <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <CheckBox x:Name="ChkLock" VerticalAlignment="Center" HorizontalAlignment="Left"
                          Checked="FeatureCheck_Changed" Unchecked="FeatureCheck_Changed"/>
                <TextBlock Grid.Column="1" Text="自动锁屏" VerticalAlignment="Center" Margin="8,0,8,0"
                           ToolTip="作用：离开时锁定工作站。&#x0a;工作：空闲到时或一键离开时执行；锁屏期间不算归来，解锁后才恢复。&#x0a;若秒数小于其它已启用离开任务，会自动抬高对齐。"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                  <TextBox x:Name="TxtLockAfter" Width="72" Height="23"
                           ToolTip="空闲多久后锁屏" LostFocus="Setting_LostFocus"/>
                  <TextBlock Text="秒" Margin="6,0,0,0" VerticalAlignment="Center" Foreground="#555555"/>
                </StackPanel>
              </Grid>
            </StackPanel>

            <StackPanel x:Name="BlockLeaveGlobal">
              <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <CheckBox x:Name="ChkRunLeaveOnManualLock" IsChecked="True" VerticalAlignment="Center"
                          HorizontalAlignment="Left"
                          Checked="Setting_Changed" Unchecked="Setting_Changed"/>
                <TextBlock Grid.Column="1" Text="手动锁屏执行离开" VerticalAlignment="Center" Margin="8,0,8,0"
