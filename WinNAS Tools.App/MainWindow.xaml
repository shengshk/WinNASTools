                  </Grid.ColumnDefinitions>
                  <ComboBox x:Name="CmbBackupDstKind" Height="23" SelectionChanged="BackupDraft_Changed"/>
                  <ComboBox x:Name="CmbBackupDstPath" Grid.Column="1" Height="23" Margin="6,0,0,0"
                            IsEditable="True" IsTextSearchEnabled="False"
                            ToolTip="本机=完整路径；主机=下拉选子目录或手填相对路径（空=根）"
                            DropDownOpened="BackupPathCombo_DropDownOpened"
                            SelectionChanged="BackupDraft_Changed"
                            LostFocus="BackupDraft_Changed"/>
                  <TextBlock x:Name="TxtBackupDstRootHint" Grid.Column="1"
                             Text="留空：使用主机根目录" Foreground="#888888"
                             Margin="12,0,24,0" VerticalAlignment="Center"
                             IsHitTestVisible="False" Visibility="Collapsed"/>
                  <Button Grid.Column="2" Content="浏览" Width="48" Margin="6,0,0,0"
                          Click="BtnBrowseBackupDst_Click"/>
                </Grid>

                <!-- 方式 + 冲突 -->
                <TextBlock Grid.Row="3" Text="方式" VerticalAlignment="Center" Margin="0,0,0,6"
                           ToolTip="复制 A→B：只把 A 有的文件拷到 B，不删 B 多余。&#x0a;镜像 A→B：先复制，再删除 B 上 A 没有的文件，使 B 与 A 一致。&#x0a;同步 A↔B：双向对齐；双方都改过时按「冲突」策略处理。"/>
                <Grid Grid.Row="3" Grid.Column="1" Margin="0,0,0,6">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="120"/>
                  </Grid.ColumnDefinitions>
                  <ComboBox x:Name="CmbBackupMode" Height="23" SelectionChanged="BackupMode_Changed"
                            ToolTip="复制 A→B：只把 A 有的文件拷到 B，不删 B 多余。&#x0a;镜像 A→B：先复制，再删除 B 上 A 没有的文件，使 B 与 A 一致。&#x0a;同步 A↔B：双向对齐；双方都改过时按「冲突」策略处理。">
                    <ComboBoxItem Content="复制 A→B" Tag="Copy" IsSelected="True"/>
                    <ComboBoxItem Content="镜像 A→B" Tag="Mirror"/>
                    <ComboBoxItem Content="同步 A↔B" Tag="Sync"/>
                  </ComboBox>
                  <TextBlock x:Name="LblConflict" Grid.Column="1" Text="冲突" VerticalAlignment="Center" Margin="8,0,6,0"/>
                  <ComboBox x:Name="CmbBackupConflict" Grid.Column="2" Height="23" SelectionChanged="BackupConflict_Changed"/>
                </Grid>

                <!-- 回收站 -->
                <TextBlock x:Name="LblTrash" Grid.Row="4" Text="回收站" VerticalAlignment="Top" Margin="0,4,0,6"/>
                <StackPanel x:Name="PanelTrashRows" Grid.Row="4" Grid.Column="1" Margin="0,0,0,6">
                  <Grid x:Name="RowCopyTrash">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtCopyTrashPath" Height="23"
                             Style="{StaticResource OptionalTextBox}"
                             Tag="留空：使用目标 B 同级 .syncbak"
                             ToolTip="覆盖前旧文件移入此目录；默认 B 同级 .syncbak"
                             TextChanged="BackupDraft_Changed"/>
                    <Button Grid.Column="1" Content="浏览" Width="48" Margin="6,0,0,0"
                            Click="BtnBrowseCopyTrash_Click"/>
                  </Grid>
                  <Grid x:Name="RowSyncTrash">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="A" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox x:Name="TxtTrashPathA" Grid.Column="1" Height="23"
                             Style="{StaticResource OptionalTextBox}"
                             Tag="留空：A 侧不使用回收站"
                             ToolTip="同步：源侧回收站，留空=不设置" TextChanged="BackupDraft_Changed"/>
                    <Button Grid.Column="2" Content="浏览" Width="48" Margin="4,0,8,0"
                            Click="BtnBrowseTrashA_Click"/>
                    <TextBlock Grid.Column="3" Text="B" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox x:Name="TxtTrashPathB" Grid.Column="4" Height="23"
                             Style="{StaticResource OptionalTextBox}"
                             Tag="留空：B 侧不使用回收站"
                             ToolTip="同步：目标侧回收站，留空=不设置" TextChanged="BackupDraft_Changed"/>
                    <Button Grid.Column="5" Content="浏览" Width="48" Margin="4,0,0,0"
                            Click="BtnBrowseTrashB_Click"/>
                  </Grid>
                </StackPanel>

                <!-- 排除 -->
                <TextBlock Grid.Row="5" Text="排除" VerticalAlignment="Top" Margin="0,4,0,6"
                           ToolTip="每行一条，支持：&#x0a;/文件夹名 — 排除该目录&#x0a;文件名 — 排除同名文件&#x0a;*后缀 或 *.后缀 — 按扩展名（如 *.tmp）"/>
                <TextBox x:Name="TxtBackupExclude" Grid.Row="5" Grid.Column="1" Height="52" Margin="0,0,0,6"
                         Style="{StaticResource OptionalTextBox}"
                         Tag="留空：不排除任何文件"
                         VerticalContentAlignment="Top" Padding="3,2"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         ToolTip="每行一条：&#x0a;/文件夹名&#x0a;文件名&#x0a;*后缀 或 *.后缀"
                         TextChanged="BackupDraft_Changed"/>

                <!-- 实时 / 计划 -->
                <TextBlock Grid.Row="6" Text="触发" VerticalAlignment="Center" Margin="0,0,0,6"/>
                <Grid Grid.Row="6" Grid.Column="1" Margin="0,0,0,6">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <ToggleButton x:Name="BtnScheduleRealtime" Grid.Column="0" Content="实时备份"
                                Style="{StaticResource SegmentToggle}"
                                Click="BtnScheduleMode_Click" Tag="Realtime"
                                ToolTip="本机源：监视文件夹变更后约 3 秒自动备份；主机源：约每 45 秒轮询一次"/>
                  <ToggleButton x:Name="BtnSchedulePlanned" Grid.Column="1" Content="计划备份"
                                Style="{StaticResource SegmentToggle}" Margin="4,0,0,0"
                                Click="BtnScheduleMode_Click" Tag="Planned"
                                ToolTip="按间隔天数 + 时刻定时执行"/>
                </Grid>

                <!-- 间隔 / 时刻（仅计划） -->
                <TextBlock x:Name="LblBackupInterval" Grid.Row="7" Text="间隔" VerticalAlignment="Center" Margin="0,0,0,6"/>
                <Grid x:Name="RowBackupSchedule" Grid.Row="7" Grid.Column="1" Margin="0,0,0,6">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="TxtBackupInterval" Width="40" Height="23" TextChanged="BackupDraft_Changed"/>
                    <TextBlock Text="天" VerticalAlignment="Center" Margin="4,0,0,0"/>
                  </StackPanel>
                  <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="时刻" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox x:Name="TxtBackupHour" Width="32" Height="23" TextChanged="BackupDraft_Changed"/>
                    <TextBlock Text=":" VerticalAlignment="Center" Margin="2,0"/>
                    <TextBox x:Name="TxtBackupMinute" Width="32" Height="23" TextChanged="BackupDraft_Changed"/>
                  </StackPanel>
                </Grid>

                <TextBlock x:Name="LblBackupNext" Grid.Row="8" Text="下次" VerticalAlignment="Center"/>
                <Grid x:Name="RowBackupNextLast" Grid.Row="8" Grid.Column="1">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock x:Name="TxtBackupNextDue" VerticalAlignment="Center" Foreground="#333333"/>
                  <TextBlock Grid.Column="1" Text="上次" VerticalAlignment="Center" Margin="12,0,6,0"/>
                  <TextBlock x:Name="TxtBackupLastRun" Grid.Column="2" VerticalAlignment="Center" Foreground="#333333"/>
                </Grid>
              </Grid>
            </StackPanel>
          </StackPanel>
          </StackPanel>
        </ScrollViewer>
      </TabItem>
    </TabControl>

    <Grid Grid.Row="2" Margin="0,8,0,4">
      <ToggleButton x:Name="BtnLogLevel" Content="运行日志 · 普通"
                    Style="{StaticResource LogFilterToggle}"
                    HorizontalAlignment="Left" Padding="10,0" IsChecked="True"
                    Click="BtnLogLevel_Click"
                    ToolTip="点击切换普通/错误日志"/>
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <Button Content="文件" Style="{StaticResource LogToolBtn}" MinWidth="48" Margin="0,0,4,0"
                Click="BtnOpenLogFile_Click"
                ToolTip="用系统默认程序打开完整日志文件"/>
        <Button Content="清除" Style="{StaticResource LogToolBtn}" MinWidth="48"
                Click="BtnClearLog_Click"
                ToolTip="清空当前界面；之后只显示清除后产生的日志，不删除后台文件"/>
      </StackPanel>
    </Grid>

    <ListBox x:Name="LstBackupProgress" Grid.Row="1"
             Margin="0,6,0,0"
             Visibility="Collapsed"
             BorderThickness="1"
             Padding="0"
             Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
             ScrollViewer.VerticalScrollBarVisibility="Auto"
             ScrollViewer.CanContentScroll="False">
      <ListBox.ItemContainerStyle>
        <Style TargetType="ListBoxItem">
          <Setter Property="Padding" Value="0"/>
          <Setter Property="Margin" Value="0"/>
          <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
          <Setter Property="Focusable" Value="False"/>
          <Setter Property="Template">
            <Setter.Value>
              <ControlTemplate TargetType="ListBoxItem">
                <ContentPresenter/>
              </ControlTemplate>
            </Setter.Value>
          </Setter>
        </Style>
      </ListBox.ItemContainerStyle>
      <ListBox.ItemTemplate>
        <DataTemplate>
          <Border Height="52" BorderBrush="#E1E1E1" BorderThickness="0,0,0,1" Padding="8,5">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>
              <TextBlock Text="{Binding HeaderText, Mode=OneWay}" FontSize="11"
                         FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
              <TextBlock Grid.Row="1" Text="{Binding TimeText, Mode=OneWay}" FontSize="10"
                         Foreground="#777777" Margin="0,2,0,0"/>
              <Button Grid.Column="1" Grid.RowSpan="2"
                      Content="{Binding ActionText, Mode=OneWay}"
                      Tag="{Binding RunId, Mode=OneWay}"
                      MinWidth="48" Margin="8,0,0,0"
                      Style="{StaticResource LogToolBtn}"
                      IsEnabled="{Binding ActionEnabled, Mode=OneWay}"
                      Click="BtnBackupProgressAction_Click"/>
              <ProgressBar Grid.Row="2" Grid.ColumnSpan="2"
                           Height="6" Margin="0,4,0,0"
                           Minimum="0" Maximum="100"
                           Value="{Binding Percent, Mode=OneWay}"
                           IsIndeterminate="{Binding IsIndeterminate, Mode=OneWay}"/>
            </Grid>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

    <TextBox x:Name="LogBox" Grid.Row="3"
             IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True"
             VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled"
             FontFamily="Consolas, Microsoft YaHei UI" FontSize="11"
             VerticalContentAlignment="Top"
             PreviewMouseWheel="LogBox_PreviewMouseWheel"
             PreviewKeyDown="LogBox_PreviewKeyDown"
             LostKeyboardFocus="LogBox_LostKeyboardFocus"/>
  </Grid>

    <StatusBar Grid.Row="1" Height="24"
               Background="#EEEEEE" BorderThickness="0"
               Padding="8,0">
      <StatusBarItem Padding="0" HorizontalContentAlignment="Stretch"
                     Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=StatusBar}}">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <TextBlock x:Name="TxtStatus" Text="状态：已停止"
                     VerticalAlignment="Center" Foreground="#555555" FontSize="11"/>
          <TextBlock x:Name="TxtStatusHotkey" Grid.Column="1"
                     VerticalAlignment="Center" Foreground="#777777" FontSize="11"
                     Margin="12,0,18,0"/>
        </Grid>
      </StatusBarItem>
    </StatusBar>
  </Grid>
</Window>
