<Window x:Class="WinNASTools.App.RemoteFolderPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择文件夹"
        Height="360" Width="420"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterOwner"
        FontFamily="Microsoft YaHei UI, Segoe UI"
        FontSize="12"
        Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <DockPanel Margin="0,0,0,8">
      <Button x:Name="BtnUp" Content="上级" Width="56" DockPanel.Dock="Right" Click="BtnUp_Click"/>
      <TextBlock x:Name="TxtCurrent" VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,8,0"/>
    </DockPanel>

    <ListBox x:Name="LstDirs" Grid.Row="1" Margin="0,0,0,8"
             MouseDoubleClick="LstDirs_MouseDoubleClick"/>

    <TextBlock x:Name="TxtStatus" Grid.Row="2" Foreground="#666666" Margin="0,0,0,8"/>

    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
      <Button Content="选择当前" Width="88" Margin="0,0,6,0" Click="BtnOk_Click" IsDefault="True"/>
      <Button Content="取消" Width="72" IsCancel="True"/>
    </StackPanel>
  </Grid>
</Window>
