<Window x:Class="WinNASTools.App.HostManageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="主机管理"
        Height="420" Width="520"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterOwner"
        FontFamily="Microsoft YaHei UI, Segoe UI"
        FontSize="12"
        Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <ListBox x:Name="LstHosts" Margin="0,0,0,8"
             SelectionChanged="LstHosts_SelectionChanged"/>

    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
      <Button Content="新建" Width="72" Margin="0,0,6,0" Click="BtnAdd_Click"/>
      <Button Content="删除" Width="72" Margin="0,0,6,0" Click="BtnDelete_Click"/>
      <Button Content="保存" Width="72" Click="BtnSave_Click"/>
    </StackPanel>

    <Grid Grid.Row="2" x:Name="PanelEdit" IsEnabled="False">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="64"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <TextBlock Text="名称" VerticalAlignment="Center" Margin="0,0,0,6"/>
      <TextBox x:Name="TxtName" Grid.Column="1" Height="23" Margin="0,0,0,6"/>

      <TextBlock Grid.Row="1" Text="类型" VerticalAlignment="Center" Margin="0,0,0,6"/>
      <ComboBox x:Name="CmbKind" Grid.Row="1" Grid.Column="1" Height="23" Margin="0,0,0,6">
        <ComboBoxItem Content="SMB" Tag="Smb" IsSelected="True"/>
        <ComboBoxItem Content="WebDAV" Tag="WebDav"/>
      </ComboBox>

      <TextBlock Grid.Row="2" Text="地址" VerticalAlignment="Center" Margin="0,0,0,6"/>
      <TextBox x:Name="TxtAddress" Grid.Row="2" Grid.Column="1" Height="23" Margin="0,0,0,6"
               ToolTip="SMB: \\server\share  WebDAV: https://host/path"/>

      <TextBlock Grid.Row="3" Text="账号" VerticalAlignment="Center" Margin="0,0,0,6"/>
      <TextBox x:Name="TxtUser" Grid.Row="3" Grid.Column="1" Height="23" Margin="0,0,0,6"/>

      <TextBlock Grid.Row="4" Text="密码" VerticalAlignment="Center" Margin="0,0,0,6"/>
      <PasswordBox x:Name="PwdPass" Grid.Row="4" Grid.Column="1" Height="23" Margin="0,0,0,6"
                   ToolTip="留空=不修改已保存密码"/>

      <TextBlock Grid.Row="5" Text="域" VerticalAlignment="Center"/>
      <TextBox x:Name="TxtDomain" Grid.Row="5" Grid.Column="1" Height="23"
               ToolTip="可选，仅 SMB 常用"/>
    </Grid>
  </Grid>
</Window>
